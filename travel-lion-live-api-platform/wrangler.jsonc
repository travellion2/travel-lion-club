{
  "$schema": "node_modules/wrangler/config-schema.json",

  "name": "travel-lion-club",

  "main": ".open-next/worker.js",

  "compatibility_date": "2025-05-29",

  "compatibility_flags": [
    "nodejs_compat"
  ],

  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },

  "observability": {
    "enabled": true
  }
}
